.seeds/issues.jsonl merge=union
.seeds/templates.jsonl merge=union
.seeds/plans.jsonl merge=union
*.pdf binary

# Keep generated source archives focused on the public runtime/docs surface.
/.agents/** export-ignore
# Dev-only push guard (blocks direct pushes to the public beta/release repos);
# not part of the public source surface.
/.githooks/** export-ignore
# Ignore the PRIVATE .claude subdirs individually — do NOT export-ignore all of
# /.claude/**, or git archive prunes the whole subtree before it sees a
# -export-ignore re-include, dropping .claude/skills/ (the public /verdict skill).
/.claude/commands/** export-ignore
/.claude/settings*.json export-ignore
/.claude/workflows/** export-ignore
/.claude/agents/** export-ignore
/obsidian-mind/** export-ignore
/evidence/** export-ignore
/docs/plans/** export-ignore
/docs/specs/** export-ignore
/docs/legacy/** export-ignore
/docs/reports/** export-ignore
/docs/internal/** export-ignore
/docs/sample-run/** export-ignore
# docs/commercial.md is a pre-publication DRAFT (open ethics/COI/ownership/license TODOs); keep it out of public exports.
/docs/commercial.md export-ignore

# Defense in depth: if private evidence or runtime state is ever force-added,
# keep it out of generated source archives.
/tmp/** export-ignore
/fixtures/** export-ignore
/test-forensics/** export-ignore
*.E01 export-ignore
*.e01 export-ignore
*.dd export-ignore
*.raw export-ignore
*.mem export-ignore
*.evtx export-ignore
*.EVTX export-ignore
*.pcap export-ignore
*.pcapng export-ignore
*.sqlite export-ignore
*.sqlite-journal export-ignore
.env export-ignore
.env.* export-ignore
.envrc export-ignore
.npmrc export-ignore
.pypirc export-ignore
.netrc export-ignore
*.pem export-ignore
*.key export-ignore
*.pkrvars.hcl export-ignore
*.pkrvars.json export-ignore
*.cookies export-ignore
*.har export-ignore
/browser-profiles/** export-ignore
/profiles/** export-ignore
