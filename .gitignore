coverage/

# External reference clones and local operator memory (never ship in release)
/openclaw/
/hermes-agent/
/Linear-Coding-Agent-Harness/
/.playwright-mcp/
/obsidian-mind/
# n8n research clones (8 repos: n8n-io/n8n, n8n-docs, czlonkowski/n8n-mcp +
# n8n-skills, Zie619/n8n-workflows, enescingoz/awesome-n8n-templates,
# nusquama/n8nworkflows.xyz, djeknet/n8n-master-workflows); see
# n8n-references/README.md for the per-clone purpose table. Wired as
# OPTIONAL operator tooling per docs/runbooks/n8n-automation-integration.md;
# never bundled in the Find Evil! submission.
/n8n-references/
# The same reference clones, now relocated under ref-folders/ or
# git-hub-references/ — also research-only, also never shipped, and
# ruff should not scan them. The git-hub-references/ tree currently
# holds 5 clones (claude-agent-sdk-python/-typescript/, openclaw/,
# hermes-agent/, awesome-openclaw-skills/); see
# git-hub-references/CLAUDE.md for the per-clone purpose table.
/ref-folders/
/git-hub-references/

# Default evidence drop directory. The directory ships (README + .gitkeep)
# so `find-evil-auto` has a documented default location, but actual
# evidence dropped here never enters git. See evidence/README.md.
/evidence/*
!/evidence/README.md
!/evidence/.gitkeep

# Smoke test working dir (Amendment A2) — produces audit logs +
# manifests under tmp/smoke/ that should never be committed.
/tmp/

# Local DFIR test corpus (SANS HACKATHON-2026 starter data + 4 host
# disk images, ~84 GB). The .E01 files are already excluded by the
# *.E01 rule above, but the multipart .zip fragments aren't — and we
# never want any of test-forensics/ in submission anyway. The
# directory stays on disk for the agent to investigate; it just
# never enters the git tree. SHA-256 manifest lives at
# test-forensics/sha256.manifest (also ignored by this rule).
/test-forensics/

# Per-session lock file written by the autonomous /loop scheduler in
# the local Claude Code install. Contains a session UUID + PID +
# acquired-at timestamp; pure ephemeral runtime state. The
# .claude/settings.json beside it is operator-local and intentionally excluded
# from the public release surface.
/.claude/scheduled_tasks.lock
# Operator-local Claude Code session permissions (blanket allows + session state)
# — not for publication. `.claude/settings*.json` is ignored above.

# Isolated dev worktrees created by superpowers:using-git-worktrees
# during subagent-driven development. Each subdir is a sibling
# checkout of the same repo on its own feature branch — never ship.
/.worktrees/

# Piper TTS model + intermediate wavs (demo video) — regenerated, not committed
scripts/make-demo-video/.tts-cache/
.elevenlabs_key

# Judge-pack PDFs (organizer material — never publish) + local demo-video
# working copy (ships only as a release asset / YouTube) + social-post and
# YouTube-Studio screenshots from the launch session. None of these may ever
# reach the public repo.
/Judging Criteria/
/docs/find-evil-demo.mp4
# Additional rendered videos (explainer, deep-dives, quickstart, contributor
# call) — hosted externally like the showcase, never committed (bulky media).
/docs/verdict-*.mp4
# Launch-session screenshots, now collected under launch-artifacts/ to keep the
# repo root clean. Root-anchored *.png patterns below are kept for any stragglers
# that land at the root during a future launch session.
/launch-artifacts/
/reddit-*.png
/old-reddit-*.png
/x-*.png
/yt-*.png
/hn-submit.png
/claudeai-*.png

# Operator-local competitive/release strategy notes and scratch plans. These are
# useful for positioning and planning, but they are not product documentation and
# should not ship in the public release repo.
/docs/competitive-analysis.md
/docs/plans/
/docs/specs/
