# Large binaries / evidence / VMs
*.ova
*.pcap
*.pcapng
*.qcow2
*.vmdk
*.vdi
*.E01
*.e01
*.dd
*.raw
*.mem
*.aff
*.aff4
*.vhd
*.vhdx
*.7z
# Windows event logs — fixture-only; never commit (real EVTX contains
# logon history, hostnames, GUIDs and other user-identifying data).
*.evtx
*.EVTX
# Memory-image evidence dropped in the repo root for local investigation
# (e.g. Rocba-Memory.zip wraps a ~5.6 GB .7z). Evidence never enters git.
/Rocba-Memory.zip
# Benchmark fixtures pulled by scripts/fetch-fixtures.sh — never committed
# (only goldens, scripts, and docs are tracked). See docs/DATASET.md.
/fixtures/

# plaso writes a timestamped run log into the CWD on every invocation — both
# stages (log2timeline + psort), from plaso_parse and the DFIR smokes. These are
# transient run logs, never evidence and never tracked.
log2timeline-*.log
log2timeline-*.log.gz
psort-*.log
psort-*.log.gz

# Rust
target/
**/*.rs.bk
# Cargo.lock IS committed — this is an application workspace with
# a shipped binary (findevil-mcp), not a library. See Rust book
# §"Cargo and Cargo.lock" for the convention.

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.pnpm-store/
.next/
out/
dist/
.turbo/
.cache/
.remotion/
# next-env.d.ts is auto-generated by Next.js on first build; checking
# it in causes spurious diffs every time someone runs `next dev`/build.
next-env.d.ts
# TypeScript incremental build cache — machine-specific binary state,
# regenerated on every tsc run with --incremental (the default in
# our apps/web/tsconfig.json).
*.tsbuildinfo

