#!/usr/bin/env bash
# DEPRECATED — merged into scripts/verdict (one command, one workflow).
# This shim forwards to it; the old --evidence flag maps to the positional arg.
echo "[find-evil-run] deprecated → use: scripts/verdict <evidence>" >&2
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ev=""
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --evidence) ev="$2"; shift 2 ;;
    *)          args+=("$1"); shift ;;
  esac
done
exec "${DIR}/verdict" ${ev:+"$ev"} ${args[@]+"${args[@]}"}
